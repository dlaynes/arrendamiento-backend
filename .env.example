# Application configuration - copy this file to .env and fill in real values
# DO NOT commit .env to version control

# Database (Production - MySQL)
DB_URL=jdbc:mysql://localhost:3306/utp_is2_arrendamiento?useSSL=false&serverTimezone=America/Lima&allowPublicKeyRetrieval=true
DB_DRIVER=com.mysql.cj.jdbc.Driver
DB_USERNAME=root
DB_PASSWORD=your_password_here
DB_DIALECT=org.hibernate.dialect.MySQLDialect

# JWT
JWT_SECRET=change-this-to-a-strong-secret-key-at-least-32-chars
JWT_EXPIRATION_MS=86400000

# CORS (adjust to your frontend URL)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads